# Hedera KMS Signer — Environment Configuration
# Copy this file to .env and fill in your values after running `cdk deploy`

# CDK Stack Outputs (populated after deployment)
API_ENDPOINT=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
USER_POOL_ID=us-east-1_XXXXXXXXX
USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_ISSUER_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
KMS_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SIGNING_FUNCTION_ARN=arn:aws:lambda:us-east-1:123456789012:function:hedera-kms-signer
AUDIT_TABLE_NAME=hedera_signing_audit

# Hedera Configuration
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.YOUR_ACCOUNT_ID
AWS_REGION=us-east-1

# Cognito Test User (create via aws cognito-idp admin-create-user)
COGNITO_USER_EMAIL=you@example.com
COGNITO_USER_PASSWORD=YourSecurePassword123!
