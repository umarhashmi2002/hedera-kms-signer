{
  "name": "hedera-kms-signer",
  "version": "1.0.0",
  "description": "Serverless Hedera transaction signing backend using AWS KMS",
  "type": "module",
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --platform=node --target=node20 --outdir=dist --format=esm",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hashgraph/sdk": "^2.55.0",
    "@aws-sdk/client-kms": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "js-sha3": "^0.9.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "fast-check": "^3.23.0",
    "@fast-check/vitest": "^0.1.3",
    "esbuild": "^0.24.0",
    "@types/aws-lambda": "^8.10.145"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
